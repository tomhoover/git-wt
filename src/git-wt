#!/usr/bin/env bash

# set -e: exit script immediately upon error
# set -u: treat unset variables as an error
# set -o pipefail: cause a pipeline to fail, if any command within it fails
set -eu -o pipefail

FORCE=""
VERBOSE=""
VERSION="0.1.0"

# Only use colors in interactive shells, not from crontab
if [ -t 1 ]; then
    RED=$(tput setaf 1)
    GREEN=$(tput setaf 2)
    # YELLOW=$(tput setaf 3)
    # BLUE=$(tput setaf 4)
    MAGENTA=$(tput setaf 5)
    CYAN=$(tput setaf 6)
    RESET=$(tput sgr0)
else
    RED=
    GREEN=
    # YELLOW=
    # BLUE=
    MAGENTA=
    CYAN=
    RESET=
fi

error() { #{{{
    echo "${RED}ERROR: ${1}${RESET}" >&2
} #}}}

success() { #{{{
    echo "${GREEN}SUCCESS: ${1}${RESET}"
} #}}}

missing_worktree_name() { #{{{
    error "'${1}' requires a worktree name"
    usage
    exit 1
} #}}}

