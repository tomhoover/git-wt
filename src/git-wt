switch_worktree() { #{{{
  if [[ "$#" -eq 0 ]]; then
    git worktree list --porcelain | awk 'NR==1{print $2}'
    return
  fi
  local branch="${1}"
  local target="${REPO_ROOT}+${branch}"
  if ! git worktree list --porcelain | grep -Fq "worktree ${target}"; then
    error "Worktree '${branch}' not found"
    exit 1
  fi
  echo "${target}"
} #}}}

completion_bash() { #{{{
  cat <<'EOF'
# shellcheck shell=bash
# Bash completion for git-wt / git wt
# Generated by: git wt completion bash

_git_wt_branches() {
  git branch --format='%(refname:short)' 2>/dev/null
}

_git_wt_worktrees() {
  git worktree list --porcelain 2>/dev/null \
    | awk '/^worktree/{p=$2} /^branch/{if(p~/\+/){sub("refs/heads/",""); print $2}}'
}

_git_wt() {
  local cur="${COMP_WORDS[COMP_CWORD]}"

  # Determine the subcommand index:
  #   'git wt <cmd>' → index 2
  #   'git-wt <cmd>' → index 1
  local subcmd_index=1
  [[ "${COMP_WORDS[0]}" == "git" ]] && subcmd_index=2

  local subcmd="${COMP_WORDS[$subcmd_index]:-}"

  case "$subcmd" in
    add | a)
      mapfile -t COMPREPLY < <(compgen -W "$(_git_wt_branches)" -- "$cur")
      ;;
    remove | rm | r | switch | sw | s)
      mapfile -t COMPREPLY < <(compgen -W "$(_git_wt_worktrees)" -- "$cur")
      ;;
    *)
      local commands="add a list ls l remove rm r prune pr p switch sw s completion version v"
      mapfile -t COMPREPLY < <(compgen -W "$commands" -- "$cur")
      ;;
  esac
}

complete -F _git_wt git-wt

# Register for 'git wt' if git's __git_complete helper is available
if declare -f __git_complete >/dev/null 2>&1; then
  __git_complete git-wt _git_wt
fi
EOF
} #}}}

completion_zsh() { #{{{
  cat <<'EOF'
#compdef git-wt

# Zsh completion for git-wt / git wt
# Generated by: git wt completion zsh

_git-wt() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a commands
  commands=(
    'add:create a worktree'
    'a:create a worktree'
    'list:list worktrees'
    'ls:list worktrees'
    'l:list worktrees'
    'remove:remove a worktree'
    'rm:remove a worktree'
    'r:remove a worktree'
    'prune:prune stale worktree references'
    'pr:prune stale worktree references'
    'p:prune stale worktree references'
    'switch:print path to worktree (no arg = main worktree)'
    'sw:print path to worktree (no arg = main worktree)'
    's:print path to worktree (no arg = main worktree)'
    'completion:output shell completion script'
    'version:print version'
    'v:print version'
  )

  _arguments -C \
    '(-h)-h[show help]' \
    '(-d --debug)'{-d,--debug}'[enable bash trace (set -x)]' \
    '(-f --force)'{-f,--force}'[force removal of dirty worktree]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '1:command:->command' \
    '*:argument:->argument'

  case $state in
    command)
      _describe 'command' commands
      ;;
    argument)
      case ${line[1]} in
        add | a)
          local -a branches
          branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
          _describe 'branch' branches
          ;;
        remove | rm | r | switch | sw | s)
          local -a worktrees
          worktrees=(${(f)"$(git worktree list --porcelain 2>/dev/null \
            | awk '/^worktree/{p=$2} /^branch/{if(p~/\+/){sub("refs/heads/",""); print $2}}')"})
          _describe 'worktree' worktrees
          ;;
      esac
      ;;
  esac
}

compdef _git-wt git-wt

# Enable 'git wt <TAB>' completion.
# git's _git completion calls _git_<subcmd> via: emulate ksh -c $completion_func
# ksh emulation makes arrays 0-indexed, so 'emulate -L zsh' restores 1-indexed behaviour.
#
# __git_zsh_main restores orig_words but does NOT restore CURRENT. Two cases arise:
#   CURRENT > $#words  — _arguments did not adjust it (virtual past-end position)
#   CURRENT <= $#words — _arguments shifted the context by (i-1) words, so
#                        effective position = i + CURRENT - 1  (where i = wt's index)
_git_wt() {
  emulate -L zsh
  local -i i
  for (( i=1; i<=$#words; i++ )); do
    [[ "${words[i]}" == wt ]] && break
  done
  local -i ec
  if (( CURRENT > $#words )); then
    ec=$CURRENT
  else
    ec=$(( i + CURRENT - 1 ))
  fi
  if (( ec == i + 1 )); then
    # Use compadd (not _describe) — _describe's tag context conflicts with _arguments ->arg
    local -a subcmds=(add a list ls l remove rm r prune pr p switch sw s completion version v)
    compadd -a subcmds
  elif (( ec > i + 1 )); then
    local subcmd='' k
    for (( k=i+1; k<ec; k++ )); do
      [[ "${words[k]}" != -* ]] && { subcmd="${words[k]}"; break; }
    done
    case "$subcmd" in
      add | a)
        local -a branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
        compadd -a branches
        ;;
      remove | rm | r | switch | sw | s)
        local -a worktrees=(${(f)"$(git worktree list --porcelain 2>/dev/null \
          | awk '/^worktree/{p=$2} /^branch/{if(p~/\+/){sub("refs/heads/",""); print $2}}')"})
        compadd -a worktrees
        ;;
    esac
  fi
}
EOF
} #}}}

add_worktree() { #{{{
  local branch="${1}"
  local target="${REPO_ROOT}+${branch}"
  if [[ "${branch}" == HEAD* ]]; then
    error "Please provide a branch name, not a commit reference"
    exit 1
  fi
  if [[ -d "${target}" ]]; then
    error "Worktree directory '${target}' already exists"
    exit 1
  fi
  # Try checking out existing branch first, then create a new one
  local branch_note
  if git worktree add "${target}" "${branch}" 2>/dev/null; then
    branch_note="existing branch"
  elif git worktree add -b "${branch}" "${target}" 2>/dev/null; then
    branch_note="new branch"
  else
    error "Failed to create worktree for '${branch}' — branch may already be checked out elsewhere"
    exit 1
  fi
  echo "${GREEN}Worktree created at: ${target}${RESET} ${CYAN}(${branch_note})${RESET}"
  echo "    ${MAGENTA}cd '${target}'${RESET}"
} #}}}

usage() { #{{{
  cat <<EOF
${CYAN}
Usage: git-wt [options] <command> [<worktree>]
       git wt [options] <command> [<worktree>]
       git wt -f [-d][-v] remove <worktree>     # the -f|--force flag is only useful for removing a dirty worktree
       cd "\$(git wt switch <worktree>)"         # switch to a worktree (wrap in a shell function for convenience)

    Options:
        -h              ) help
        -d | --debug    ) debugging info displayed
        -f | --force    ) force removal of dirty worktree
        -v | --verbose  ) verbose

    Commands:
        a | add         ) add a worktree
        l | ls | list   ) list worktrees
        r | rm | remove ) the -f|--force flag is only useful for removing a dirty worktree
        p | pr | prune  ) prune worktrees
        s | sw | switch ) print path to worktree; no arg = main worktree (use: cd "\$(git wt switch [<worktree>])")
        completion      ) output shell completion script (use: eval "\$(git wt completion bash|zsh)")
        v | version     ) display version
${RESET}
EOF
} #}}}

process_arguments() { #{{{
  # shopt -s nocasematch
  while [[ "$#" -ge 1 ]]; do
    case "${1}" in
      -h)
        usage
        exit 0
        ;;
      -d | --debug)
        set -x
        shift
        continue
        ;;
      -f | --force)
        FORCE=true
        shift
        continue
        ;;
      -v | --verbose)
        VERBOSE=true
        shift
        continue
        ;;
      a | add)
        shift
        if [[ "$#" -ge 1 ]]; then
          add_worktree "${1}"
        else
          missing_worktree_name "add"
        fi
        break
        ;;
      l | ls | list)
        # Note: pwd -P resolves symlinks; highlighting may not match if worktree was added via a symlinked path
        git worktree list | awk \
          -v pwd="$(pwd -P)" \
          -v bold="${BOLD}" \
          -v green="${GREEN}" \
          -v cyan="${CYAN}" \
          -v reset="${RESET}" \
          '{
            rest = substr($0, length($1) + 1)
            if ($1 == pwd) printf "* %s%s%s%s%s\n", bold, green, $1, reset, cyan rest reset
            else           printf "  %s\n", $0
          }'
        break
        ;;
      r | rm | remove)
        shift
        if [[ "$#" -ge 1 ]]; then
          if ! git worktree list --porcelain | grep -Fq "worktree ${REPO_ROOT}+${1}"; then
            error "Worktree '${1}' not found"
            exit 1
          else
            # ${FORCE:+-f} intentionally unquoted — empty expansion must pass no argument
            # shellcheck disable=SC2086 # intentionally unquoted for optional flag expansion
            git worktree remove ${FORCE:+-f} "${REPO_ROOT}+${1}"
            success "Worktree '${1}' removed successfully"
          fi
        else
          missing_worktree_name "remove"
        fi
        break
        ;;
      s | sw | switch)
        shift
        if [[ "$#" -ge 1 ]]; then
          switch_worktree "${1}"
        else
          switch_worktree
        fi
        break
        ;;
      p | pr | prune)
        git worktree prune ${VERBOSE:+-v}
        success "Prune complete"
        break
        ;;
      completion)
        shift
        case "${1:-}" in
          bash) completion_bash ;;
          zsh) completion_zsh ;;
          *)
            error "Unknown shell: '${1:-}'. Supported: bash, zsh"
            exit 1
            ;;
        esac
        break
        ;;
      v | version)
        echo "git-wt version ${VERSION}"
        break
        ;;
      *)
        error "Unknown argument: ${1}"
        usage
        exit 1
        ;;
    esac
  done
} #}}}

case "${1:-}" in
  "" | completion | v | version | -h) ;;
  *)
    if ! git rev-parse --git-dir &>/dev/null; then
      error "Not inside a git repository"
      exit 1
    fi
    REPO_ROOT="$(git rev-parse --show-toplevel)"
    ;;
esac

if [[ "$#" -eq 0 ]]; then
  usage
else
  process_arguments "$@"
fi

