#!/usr/bin/env bash

# set -e: exit script immediately upon error
# set -u: treat unset variables as an error
# set -o pipefail: cause a pipeline to fail, if any command within it fails
set -eu -o pipefail

VERSION=0.23.0
PROG="${GIT_WT_CALLER:-git wt}"
REPO_ROOT='' # set by the entry-point guard for commands that require a git repo

# Only use colors in interactive shells, not from crontab; honor NO_COLOR (https://no-color.org)
if [ -t 1 ] && [[ -z "${NO_COLOR:-}" ]]; then
  RED=$(tput setaf 1)
  GREEN=$(tput setaf 2)
  MAGENTA=$(tput setaf 5)
  CYAN=$(tput setaf 6)
  BOLD=$(tput bold)
  RESET=$(tput sgr0)
else
  RED=
  GREEN=
  MAGENTA=
  CYAN=
  BOLD=
  RESET=
fi

error() { #{{{
  echo "${RED}ERROR: ${1}${RESET}" >&2
} #}}}

success() { #{{{
  echo "${GREEN}SUCCESS: ${1}${RESET}"
} #}}}

warn() { #{{{
  echo "${MAGENTA}WARNING: ${1}${RESET}" >&2
} #}}}

init_shell() { #{{{
  cat <<'EOF'
wt() {
  case "${1:-}" in
    c | cd)
      local _wt_dir
      _wt_dir="$(GIT_WT_CALLER=wt git wt cd "${@:2}")" || return 1
      cd "$_wt_dir"
      ;;
    a | add)
      local _do_cd=0 _arg
      [[ -n "${GIT_WT_ADD_CD:-}" ]] && _do_cd=1
      for _arg in "$@"; do [[ "${_arg}" == "--cd" ]] && _do_cd=1; done
      if (( _do_cd )); then
        local _cd_file _wt_path _rc
        _cd_file=$(mktemp)
        GIT_WT_CALLER=wt GIT_WT_CD_FILE="${_cd_file}" git wt "$@"; _rc=$?
        if [[ $_rc -eq 0 ]]; then
          _wt_path=$(cat "${_cd_file}" 2>/dev/null)
          [[ -n "${_wt_path}" ]] && cd "${_wt_path}"
        fi
        rm -f "${_cd_file}"
        return $_rc
      else
        GIT_WT_CALLER=wt git wt "$@"
      fi
      ;;
    *)
      GIT_WT_CALLER=wt git wt "$@"
      ;;
  esac
}
EOF
} #}}}

completion_bash() { #{{{
  cat <<'EOF'
# shellcheck shell=bash
# Bash completion for git-wt / git wt
# Generated by: git wt completion bash

_git_wt_branches() {
  git branch --format='%(refname:short)' 2>/dev/null
}

_git_wt_worktrees() {
  git worktree list --porcelain 2>/dev/null \
    | awk '/^worktree/{p=$2} /^branch/{if(p~/\+/){sub("refs/heads/",""); print $2}}'
}

_git_wt() {
  local cur="${COMP_WORDS[COMP_CWORD]}"

  # Determine the subcommand index:
  #   'git wt <cmd>' or 'g wt <cmd>' → index 2
  #   'git-wt <cmd>'                 → index 1
  local subcmd_index=1
  [[ "${COMP_WORDS[1]:-}" == "wt" ]] && subcmd_index=2

  local subcmd="${COMP_WORDS[$subcmd_index]:-}"

  case "$subcmd" in
    add | a)
      mapfile -t COMPREPLY < <(compgen -W "--cd $(_git_wt_branches)" -- "$cur")
      ;;
    remove | rm | r)
      mapfile -t COMPREPLY < <(compgen -W "-f --force -d --delete-branch $(_git_wt_worktrees)" -- "$cur")
      ;;
    cd | c)
      mapfile -t COMPREPLY < <(compgen -W "$(_git_wt_worktrees)" -- "$cur")
      ;;
    *)
      local commands="add a list ls l remove rm r prune pr p cd c status st s completion init version v"
      mapfile -t COMPREPLY < <(compgen -W "$commands" -- "$cur")
      ;;
  esac
}

complete -F _git_wt git-wt
complete -F _git_wt wt

# Register for 'git wt' if git's __git_complete helper is available
if declare -f __git_complete >/dev/null 2>&1; then
  __git_complete git-wt _git_wt
fi
EOF
} #}}}

# NOTE: the worktree-branch awk snippet inside completion_zsh is identical to the one
# in completion_bash. They cannot share a helper because each function emits standalone
# shell code for the user's shell process, which cannot call back into git-wt internals.
completion_zsh() { #{{{
  cat <<'EOF'
#compdef git-wt

# Zsh completion for git-wt / git wt
# Generated by: git wt completion zsh

_git_wt_worktree_branches() {
  git worktree list --porcelain 2>/dev/null \
    | awk '/^worktree/{p=$2} /^branch/{if(p~/\+/){sub("refs/heads/",""); print $2}}'
}

_git-wt() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a commands
  commands=(
    'add:create a worktree'
    'a:create a worktree'
    'list:list worktrees'
    'ls:list worktrees'
    'l:list worktrees'
    'remove:remove a worktree'
    'rm:remove a worktree'
    'r:remove a worktree'
    'prune:prune stale worktree references'
    'pr:prune stale worktree references'
    'p:prune stale worktree references'
    'cd:print path to worktree and cd into it (no arg = main worktree)'
    'c:print path to worktree and cd into it (no arg = main worktree)'
    'status:show git status across all worktrees'
    'st:show git status across all worktrees'
    's:show git status across all worktrees'
    'completion:output shell completion script'
    'init:output shell integration function (wt)'
    'version:print version'
    'v:print version'
  )

  _arguments -C \
    '(-h)-h[show help]' \
    '--debug[enable bash trace (set -x)]' \
    '1:command:->command' \
    '*:argument:->argument'

  case $state in
    command)
      _describe 'command' commands
      ;;
    argument)
      case ${line[1]} in
        add | a)
          local -a branches opts
          opts=(--cd)
          branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
          compadd -a opts
          _describe 'branch' branches
          ;;
        remove | rm | r)
          _arguments \
            '(-f --force)'{-f,--force}'[force removal of dirty worktree]' \
            '(-d --delete-branch)'{-d,--delete-branch}'[delete branch after removing worktree]' \
            '*:worktree:(${(f)"$(_git_wt_worktree_branches)"})'
          ;;
        cd | c)
          local -a worktrees
          worktrees=(${(f)"$(_git_wt_worktree_branches)"})
          _describe 'worktree' worktrees
          ;;
      esac
      ;;
  esac
}

compdef _git-wt git-wt

# Enable 'git wt <TAB>' completion.
# git's _git completion calls _git_<subcmd> via: emulate ksh -c $completion_func
# ksh emulation makes arrays 0-indexed, so 'emulate -L zsh' restores 1-indexed behaviour.
#
# __git_zsh_main restores orig_words but does NOT restore CURRENT. Two cases arise:
#   CURRENT > $#words  — _arguments did not adjust it (virtual past-end position)
#   CURRENT <= $#words — _arguments shifted the context by (i-1) words, so
#                        effective position = i + CURRENT - 1  (where i = wt's index)
_git_wt() {
  emulate -L zsh
  local -i i
  for (( i=1; i<=$#words; i++ )); do
    [[ "${words[i]}" == wt ]] && break
  done
  local -i ec
  if (( CURRENT > $#words )); then
    ec=$CURRENT
  else
    ec=$(( i + CURRENT - 1 ))
  fi
  if (( ec == i + 1 )); then
    # Use compadd (not _describe) — _describe's tag context conflicts with _arguments ->arg
    local -a subcmds=(add a list ls l remove rm r prune pr p cd c status st s completion init version v)
    compadd -a subcmds
  elif (( ec > i + 1 )); then
    local subcmd='' k
    for (( k=i+1; k<ec; k++ )); do
      [[ "${words[k]}" != -* ]] && { subcmd="${words[k]}"; break; }
    done
    case "$subcmd" in
      add | a)
        local -a branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
        local -a opts=(--cd)
        compadd -a opts
        compadd -a branches
        ;;
      remove | rm | r)
        local -a opts=(-f --force -d --delete-branch)
        local -a worktrees=(${(f)"$(_git_wt_worktree_branches)"})
        compadd -a opts
        compadd -a worktrees
        ;;
      cd | c)
        local -a worktrees=(${(f)"$(_git_wt_worktree_branches)"})
        compadd -a worktrees
        ;;
    esac
  fi
}

compdef _git_wt wt
EOF
} #}}}

_list_worktrees_raw() { #{{{
  # Emit one tab-separated line per worktree: <path>\t<head7>\t<branch>
  # branch is empty string for detached HEAD, "(bare)" for bare repos.
  git worktree list --porcelain \
    | awk '
        /^worktree/ { path = $2; head = ""; br = "" }
        /^HEAD/     { head = substr($2, 1, 7) }
        /^branch/   { br = $2; sub("refs/heads/", "", br) }
        /^detached/ { br = "" }
        /^bare/     { br = "(bare)" }
        /^$/        { if (path != "") { print path "\t" head "\t" br; path = "" } }
        END         { if (path != "") print path "\t" head "\t" br }
      '
} #}}}

status_worktrees() { #{{{
  local cur_path
  cur_path=$(pwd -P)
  local wt_head # unused here; read for field alignment with list_worktrees
  while IFS=$'\t' read -r wt_path wt_head wt_branch; do
    local marker='' files=''
    [[ "${wt_path}" == "${cur_path}" ]] && marker="${GREEN}*${RESET}" || marker=" "
    if [[ ! -d "${wt_path}" ]]; then
      files="${RED}broken (directory missing)${RESET}"
    elif ! files=$(git -C "${wt_path}" status --short 2>/dev/null); then
      files="${RED}broken (inaccessible)${RESET}"
    else
      files=$(printf '%s' "${files}" | tr '\n' ' ')
      files="${files% }"
      [[ -z "${files}" ]] && files="${GREEN}clean${RESET}" || files="${RED}${files}${RESET}"
    fi
    printf "%s ${BOLD}${GREEN}%s${RESET}  ${CYAN}[%s]${RESET}  %s\n" \
      "${marker}" "${wt_path}" "${wt_branch:-detached}" "${files}"
  done < <(_list_worktrees_raw)
} #}}}

_fzf_select_worktree() { #{{{
  local fzf_cmd="${1}"
  shift
  printf '%s\n' "$@" | "${fzf_cmd}" --height=40% --reverse --no-sort || return 1
} #}}}

cd_worktree() { #{{{
  # Resolve fzf: GIT_WT_FZF overrides auto-detection (useful for testing)
  local fzf_bin=''
  if [[ -n "${GIT_WT_FZF:-}" ]]; then
    fzf_bin="${GIT_WT_FZF}"
  elif command -v fzf &>/dev/null && [[ -t 2 ]]; then
    fzf_bin="fzf"
  fi

  # Collect all worktree paths in a single git call
  local -a all_paths=()
  while IFS= read -r p; do all_paths+=("${p}"); done \
    < <(git worktree list --porcelain | awk '/^worktree/{print $2}')
  local main_root="${all_paths[0]}"

  if [[ "$#" -eq 0 ]]; then
    if [[ "${#all_paths[@]}" -le 1 ]] || [[ -z "${fzf_bin}" ]]; then
      echo "${main_root}"
    else
      _fzf_select_worktree "${fzf_bin}" "${all_paths[@]}" || exit 1
    fi
    return
  fi

  local prefix="${main_root}+"
  local branch="${1//\//+}"
  local target="${prefix}${branch}"

  # Exact match
  local p
  for p in "${all_paths[@]}"; do
    if [[ "${p}" == "${target}" ]]; then
      echo "${target}"
      return
    fi
  done

  # Prefix match: match q against any +-delimited segment of each linked worktree's
  # path suffix relative to the main repo root (e.g. "claude+testing" → segments
  # "claude" and "testing"), so that both branch name and parent path components match.
  # Uses index() rather than split(...,"+") to avoid BSD awk treating "+" as an ERE
  # quantifier with no preceding atom.
  local -a matches=()
  while IFS= read -r match; do
    matches+=("${match}")
  done < <(printf '%s\n' "${all_paths[@]}" \
    | awk -v main="${main_root}" -v q="${branch}" '
        {
          path = $0
          if (path == main) next
          base = main "+"
          if (substr(path, 1, length(base)) != base) next
          suffix = substr(path, length(base) + 1)
          if (substr(suffix, 1, length(q)) == q || index(suffix, "+" q) > 0) print path
        }
      ')

  if [[ "${#matches[@]}" -eq 1 ]]; then
    echo "${matches[0]}"
  elif [[ "${#matches[@]}" -eq 0 ]]; then
    error "Worktree '${branch}' not found"
    exit 1
  elif [[ -n "${fzf_bin}" ]]; then
    _fzf_select_worktree "${fzf_bin}" "${matches[@]}" || exit 1
  else
    error "Ambiguous worktree '${branch}' — matches:"
    for match in "${matches[@]}"; do
      echo "  ${match#"${prefix}"}" >&2
    done
    exit 1
  fi
} #}}}

list_worktrees() { #{{{
  # Note: pwd -P resolves symlinks; highlighting may not match if worktree was added via a symlinked path
  local cur_path
  cur_path=$(pwd -P)
  while IFS=$'\t' read -r wt_path wt_head wt_branch; do
    local dirty='' status_out=''
    if [[ ! -d "${wt_path}" ]]; then
      dirty=" ${RED}!! (directory missing)${RESET}"
    elif ! status_out=$(git -C "${wt_path}" status --short 2>/dev/null); then
      dirty=" ${RED}!! (inaccessible)${RESET}"
    elif [[ -n "${status_out}" ]]; then
      dirty=" ${RED}!${RESET}"
    fi
    if [[ "${wt_path}" == "${cur_path}" ]]; then
      printf "* ${BOLD}${GREEN}%s${RESET}  %s [%s]%s\n" \
        "${wt_path}" "${wt_head}" "${wt_branch:-detached}" "${dirty}"
    else
      printf "  %s  %s [%s]%s\n" \
        "${wt_path}" "${wt_head}" "${wt_branch:-detached}" "${dirty}"
    fi
  done < <(_list_worktrees_raw)
} #}}}

missing_worktree_name() { #{{{
  error "'${1}' requires a worktree name"
  usage
  exit 1
} #}}}

maybe_mise_trust() { #{{{
  local target="${1}"
  local mise_bin="${GIT_WT_MISE:-}"
  if [[ -z "${mise_bin}" ]] && command -v mise &>/dev/null; then
    mise_bin="mise"
  fi
  [[ -z "${mise_bin}" ]] && return 0
  if "${mise_bin}" trust "${target}" &>/dev/null; then
    echo "    ${CYAN}mise trust applied${RESET}"
  else
    warn "mise trust failed for '${target}'"
  fi
} #}}}

_cp_cow_flags() { #{{{
  if [[ "$(uname -s)" == "Darwin" ]]; then
    local major
    major="$(sw_vers -productVersion 2>/dev/null | cut -d. -f1)"
    if [[ "${major}" =~ ^[0-9]+$ ]] && [[ "${major}" -ge 12 ]]; then
      echo "-c -r"
    else
      echo "-r"
    fi
  else
    echo "--reflink=auto -r"
  fi
} #}}}

copy_worktree_files() { #{{{
  local main_root="${1}"
  local target="${2}"
  local config_file="${main_root}/.git-wt-copy"
  [[ -f "${config_file}" ]] || return 0

  local cp_flags
  cp_flags="$(_cp_cow_flags)"
  local copied=0

  while IFS= read -r raw; do
    # Strip leading/trailing whitespace
    local entry="${raw#"${raw%%[! ]*}"}"
    entry="${entry%"${entry##*[! ]}"}"
    # Skip blank lines and comments
    [[ -z "${entry}" || "${entry}" == \#* ]] && continue
    # Strip trailing slash (directories may include it for clarity)
    entry="${entry%/}"
    # Reject absolute paths or paths with ..
    if [[ "${entry}" == /* || "${entry}" == *..* ]]; then
      warn ".git-wt-copy: skipping invalid path '${entry}'"
      continue
    fi
    local src="${main_root}/${entry}"
    local dst="${target}/${entry}"
    if [[ ! -e "${src}" ]]; then
      warn ".git-wt-copy: '${entry}' not found in main worktree, skipping"
      continue
    fi
    if [[ -e "${dst}" ]]; then
      warn ".git-wt-copy: '${entry}' already exists in new worktree, skipping"
      continue
    fi
    mkdir -p "$(dirname "${dst}")"
    # shellcheck disable=SC2086
    if ! cp ${cp_flags} "${src}" "${dst}" 2>/dev/null; then
      # CoW may fail on some filesystems; retry with plain copy
      if ! cp -r "${src}" "${dst}"; then
        warn ".git-wt-copy: failed to copy '${entry}'"
        continue
      fi
    fi
    copied=$((copied + 1))
  done <"${config_file}"

  if [[ "${copied}" -gt 0 ]]; then
    echo "    ${CYAN}Copied ${copied} item(s) from .git-wt-copy${RESET}"
  fi
} #}}}

add_worktree() { #{{{
  local branch="${1}"
  local base="${2:-}"
  local cd_after="${3:-}"
  if [[ "${branch}" == HEAD* ]]; then
    error "Please provide a branch name, not a commit reference"
    exit 1
  fi
  local target_root="${REPO_ROOT}"
  if [[ -n "${base}" ]]; then
    local base_wt_path
    base_wt_path=$(git worktree list --porcelain \
      | awk -v b="${base}" '
          /^worktree/ { path = $2 }
          /^branch/ {
            br = $2; sub("refs/heads/", "", br)
            if (br == b) { print path; exit }
          }
        ')
    [[ -n "${base_wt_path}" ]] && target_root="${base_wt_path}"
  fi
  local target="${target_root}+${branch//\//+}"
  if [[ -d "${target}" ]]; then
    error "Worktree directory '${target}' already exists"
    exit 1
  fi
  # Try checking out existing branch first (handles DWIM from remotes), then create a new one.
  # If a base is specified, skip straight to creating a new branch from that base.
  local branch_note git_out
  if [[ -n "${base}" ]]; then
    if git_out=$(git worktree add -b "${branch}" "${target}" "${base}" 2>&1); then
      branch_note="new branch from ${base}"
      echo "${git_out}"
    else
      echo "${git_out}" >&2
      error "Failed to create worktree for '${branch}' from '${base}'"
      exit 1
    fi
  elif git_out=$(git worktree add "${target}" "${branch}" 2>&1); then
    branch_note="existing branch"
    [[ -n "${git_out}" ]] && echo "${git_out}"
  else
    if git_out=$(git worktree add -b "${branch}" "${target}" 2>&1); then
      branch_note="new branch"
      echo "${git_out}"
    else
      echo "${git_out}" >&2
      error "Failed to create worktree for '${branch}'"
      exit 1
    fi
  fi
  echo "${GREEN}Worktree created at: ${target}${RESET} ${CYAN}(${branch_note})${RESET}"
  if [[ -n "${cd_after}" && "${PROG}" == "wt" && -n "${GIT_WT_CD_FILE:-}" ]]; then
    echo "${target}" >"${GIT_WT_CD_FILE}"
  else
    echo "    ${MAGENTA}cd '${target}'${RESET}"
  fi
  maybe_mise_trust "${target}"
  copy_worktree_files "${REPO_ROOT}" "${target}"
} #}}}

usage() { #{{{
  if [[ "${PROG}" == "wt" ]]; then
    cat <<EOF
${CYAN}
Usage: wt [options] <command> [<worktree>]
       wt [--debug] remove [-f|--force] [-d|--delete-branch] <worktree>
       wt cd [<worktree>]

    Options:
        -h              ) help
        --debug         ) debugging info displayed

    Commands:
        a | add         ) add a worktree; optional [<base>] creates new branch from base instead of HEAD; --cd changes into new worktree after creation (default: set GIT_WT_ADD_CD=1)
        l | ls | list   ) list worktrees ('${RED}!${CYAN}' = dirty, '${RED}!! (directory missing)${CYAN}' / '${RED}!! (inaccessible)${CYAN}' = broken)
        r | rm | remove ) [-f|--force] [-d|--delete-branch] remove a worktree (-f removes dirty worktree; branch is never force-deleted)
        p | pr | prune  ) prune worktrees
        c | cd          ) cd into worktree; no arg = main worktree
        s | st | status ) show git status across all worktrees
        completion      ) output shell completion script (use: eval "\$(git wt completion bash|zsh)")
        init            ) output shell integration function (use: eval "\$(git wt init bash|zsh)")
        v | version     ) display version
${RESET}
EOF
  else
    cat <<EOF
${CYAN}
Usage: git-wt [options] <command> [<worktree>]
       git wt [options] <command> [<worktree>]
       git wt [--debug] remove [-f|--force] [-d|--delete-branch] <worktree>
       cd "\$(git wt cd <worktree>)"              # cd to a worktree (wrap in a shell function for convenience)

    Options:
        -h              ) help
        --debug         ) debugging info displayed

    Commands:
        a | add         ) add a worktree; optional [<base>] creates new branch from base instead of HEAD; --cd changes into new worktree after creation (default: set GIT_WT_ADD_CD=1)
        l | ls | list   ) list worktrees ('${RED}!${CYAN}' = dirty, '${RED}!! (directory missing)${CYAN}' / '${RED}!! (inaccessible)${CYAN}' = broken)
        r | rm | remove ) [-f|--force] [-d|--delete-branch] remove a worktree (-f removes dirty worktree; branch is never force-deleted)
        p | pr | prune  ) prune worktrees
        c | cd          ) print path to worktree; no arg = main worktree (use: cd "\$(git wt cd [<worktree>])")
        s | st | status ) show git status across all worktrees
        completion      ) output shell completion script (use: eval "\$(git wt completion bash|zsh)")
        init            ) output shell integration function (use: eval "\$(git wt init bash|zsh)")
        v | version     ) display version
${RESET}
EOF
  fi
} #}}}

process_arguments() { #{{{
  while [[ "$#" -ge 1 ]]; do
    case "${1}" in
      # options #{{{
      -h)
        usage
        exit 0
        ;;
      --debug)
        set -x
        shift
        continue
        ;;
      # }}}
      a | add) #{{{
        shift
        local cd_after=""
        local -a add_args=()
        while [[ "$#" -ge 1 ]]; do
          case "${1}" in
            --cd) cd_after=true ;;
            *) add_args+=("${1}") ;;
          esac
          shift
        done
        [[ -n "${GIT_WT_ADD_CD:-}" && "${PROG}" == "wt" ]] && cd_after=true
        if [[ "${#add_args[@]}" -ge 1 ]]; then
          if [[ "${#add_args[@]}" -gt 2 ]]; then
            error "Too many arguments: unexpected '${add_args[2]}'"
            exit 1
          fi
          add_worktree "${add_args[0]}" "${add_args[1]:-}" "${cd_after}"
        else
          missing_worktree_name "add"
        fi
        break
        ;;
      # }}}
      l | ls | list) #{{{
        list_worktrees
        break
        ;;
      # }}}
      r | rm | remove) #{{{
        shift
        local force="" delete_branch=""
        while [[ "${1:-}" == -* ]]; do
          case "${1}" in
            -f | --force) force=true ;;
            -d | --delete-branch) delete_branch=true ;;
            *)
              error "Unknown option '${1}'"
              exit 1
              ;;
          esac
          shift
        done
        if [[ "$#" -ge 1 ]]; then
          local wt_name="${1}"
          shift
          if [[ "$#" -ge 1 ]]; then
            error "Too many arguments: unexpected '${1}'"
            exit 1
          fi
          local wt_path branch=""
          wt_path=$(cd_worktree "${wt_name}")
          branch=$(git worktree list --porcelain \
            | awk -v p="${wt_path}" \
              '$0=="worktree "p{f=1; next} f && /^$/{exit} f && /^branch/{sub("refs/heads/",""); print $2; exit}')
          # ${force:+-f} intentionally unquoted — empty expansion must pass no argument
          # shellcheck disable=SC2086 # intentionally unquoted for optional flag expansion
          git worktree remove ${force:+-f} "${wt_path}"
          success "Worktree '${branch:-${wt_name}}' removed successfully"
          if [[ -n "${delete_branch}" ]]; then
            if [[ -n "${branch}" ]]; then
              git branch -d "${branch}"
              success "Branch '${branch}' deleted"
            else
              warn "Cannot delete branch: worktree was in detached HEAD state"
            fi
          fi
        else
          missing_worktree_name "remove"
        fi
        break
        ;;
      # }}}
      c | cd) #{{{
        shift
        if [[ "$#" -ge 1 ]]; then
          cd_worktree "${1}"
        else
          cd_worktree
        fi
        break
        ;;
      # }}}
      s | st | status) #{{{
        status_worktrees
        break
        ;;
      # }}}
      p | pr | prune) #{{{
        git worktree prune -v
        success "Prune complete"
        break
        ;;
      # }}}
      completion) #{{{
        shift
        case "${1:-}" in
          bash) completion_bash ;;
          zsh) completion_zsh ;;
          *)
            error "Unknown shell: '${1:-}'. Supported: bash, zsh"
            exit 1
            ;;
        esac
        break
        ;;
      # }}}
      init) #{{{
        shift
        # init_shell emits a shell-agnostic snippet; bash and zsh both use the same output
        case "${1:-}" in
          bash | zsh) init_shell ;;
          *)
            error "Unknown shell: '${1:-}'. Supported: bash, zsh"
            exit 1
            ;;
        esac
        break
        ;;
      # }}}
      v | version) #{{{
        echo "git-wt version ${VERSION}"
        break
        ;;
      # }}}
      *) #{{{
        error "Unknown argument: ${1}"
        usage
        exit 1
        ;;
        # }}}
    esac
  done
} #}}}

case "${1:-}" in
  "" | completion | init | v | version | -h) ;;
  *)
    if ! git rev-parse --git-dir &>/dev/null; then
      error "Not inside a git repository"
      exit 1
    fi
    REPO_ROOT="$(git rev-parse --show-toplevel)"
    ;;
esac

if [[ "$#" -eq 0 ]]; then
  usage
else
  process_arguments "$@"
fi

