#!/usr/bin/env bash

# Validates that a commit message follows Conventional Commits format.
# Usage: check-commit-msg <commit-msg-file>
# See: https://www.conventionalcommits.org/

set -eu -o pipefail

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?(!)?: .+'

msg=$(head -1 "$1")

if ! echo "${msg}" | grep -qE "${pattern}"; then
  echo "ERROR: commit message does not follow Conventional Commits format"
  echo "  Expected: <type>[optional scope][optional !]: <description>"
  echo "  Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo "  Got: ${msg}"
  exit 1
fi

# vim: set tw=100 expandtab tabstop=2 shiftwidth=2:
